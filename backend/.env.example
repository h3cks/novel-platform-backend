# URL до твоєї бази даних PostgreSQL
DATABASE_URL="postgresql://devuser:devpass@localhost:5432/novel_db?schema=public"

# Порт для бекенду
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# JWT secret (якщо плануєш токени)
EMAIL_CONFIRM_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_HOURS=1
JWT_SECRET=supersecretkey123
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
EMAIL_FROM="Novel Platform <no-reply@novel.local>"

MIN_WORDS_TOTAL=5000
MIN_CHAPTERS=1
MIN_WORDS_PER_CHAPTER=100
MAX_EXTERNAL_LINKS=5
MAX_COMPARE_CHAPTERS=50
DUPLICATE_CONTENT_THRESHOLD=0.6
LANG_DETECTION_ENABLED=true
